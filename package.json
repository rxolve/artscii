{
  "name": "artscii",
  "version": "0.1.0",
  "description": "ASCII art search API for agents",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "artscii": "dist/mcp.js"
  },
  "files": [
    "dist/",
    "arts/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "mcp": "tsx src/mcp.ts",
    "convert": "python3 scripts/convert_all.py",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ascii-art",
    "terminal",
    "mcp",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rxolve/artscii.git"
  },
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
