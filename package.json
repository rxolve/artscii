{
  "name": "artscii",
  "version": "0.3.4",
  "description": "ASCII art & kaomoji search MCP server for AI agents",
  "mcpName": "io.github.rxolve/artscii",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "artscii": "dist/mcp.js"
  },
  "files": [
    "dist/",
    "arts/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "mcp": "tsx src/mcp.ts",
    "convert": "python3 scripts/convert_all.py",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ascii-art",
    "terminal",
    "mcp",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rxolve/artscii.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "figlet": "^1.11.0",
    "hono": "^4.12.9",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
